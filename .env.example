# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/screenshot-saas

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Polar
POLAR_ACCESS_TOKEN=polar_at_...
POLAR_ORGANIZATION_ID=org_...
POLAR_WEBHOOK_SECRET=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# E2E Testing (optional — enables production smoke testing via x-e2e-token header)
# Generate with: openssl rand -hex 64
E2E_TEST_SECRET=
# Only needed when running the E2E suite (not on the server)
E2E_TARGET_URL=http://localhost:3001
