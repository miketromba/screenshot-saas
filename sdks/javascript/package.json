{
	"name": "@screenshotapi/sdk",
	"version": "1.0.0",
	"description": "Official JavaScript/TypeScript SDK for ScreenshotAPI",
	"license": "MIT",
	"author": "ScreenshotAPI",
	"repository": {
		"type": "git",
		"url": "https://github.com/miketromba/screenshotapi-js"
	},
	"keywords": [
		"screenshot",
		"api",
		"screenshotapi",
		"webpage",
		"capture"
	],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.5.0"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
