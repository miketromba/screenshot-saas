{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"crons": [
		{
			"path": "/api/cron/cache-cleanup",
			"schedule": "0 3 * * *"
		}
	],
	"redirects": [
		{
			"source": "/:path(.*)",
			"has": [{ "type": "host", "value": "www.screenshotapi.to" }],
			"destination": "https://screenshotapi.to/:path",
			"permanent": true
		}
	]
}
