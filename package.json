{
	"name": "screenshot-saas",
	"private": true,
	"packageManager": "bun@1.3.11",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"db:generate": "turbo db:generate",
		"db:generate:custom": "turbo db:generate:custom",
		"db:migrate": "turbo db:migrate",
		"db:studio": "turbo db:studio",
		"prepare": "husky"
	},
	"overrides": {
		"elysia": "1.4.28"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.11",
		"husky": "^9.1.7",
		"turbo": "^2.8.20",
		"typescript": "^6.0.2"
	}
}
